# =====================================================================
# DocketLens — env example
# Copy to .env.local for development, set in Vercel for deployments.
# =====================================================================

# --- Database ---------------------------------------------------------
# Local dev uses SQLite. For prod, point at Postgres (Neon, Supabase, etc.)
DATABASE_URL="file:./docketlens.db"

# --- CourtListener (data source) -------------------------------------
# Sign up free at https://www.courtlistener.com/sign-in/ then copy from
# https://www.courtlistener.com/profile/api-token/
# Rate limits: 5 req/min, 50 req/hr, 125 req/day per token.
COURTLISTENER_TOKEN=""
COURTLISTENER_BASE_URL="https://www.courtlistener.com/api/rest/v4"

# --- Anthropic Claude (AI summaries) ---------------------------------
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL_SUMMARY="claude-haiku-4-5-20251001"
ANTHROPIC_MODEL_DEEP="claude-sonnet-4-6"

# --- Auth -------------------------------------------------------------
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-in-production-please"
BETTER_AUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Email (alert delivery) -------------------------------------------
RESEND_API_KEY=""
RESEND_FROM="DocketLens <alerts@docketlens.ai>"

# --- Billing (Stripe) -------------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_TEAM=""

# --- Observability ----------------------------------------------------
POSTHOG_KEY=""

# --- Public (NEXT_PUBLIC_*) ------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_POSTHOG_KEY=""
